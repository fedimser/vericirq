   "source": [
    "import z3\n",
    "\n",
    "a = z3.BitVec(\"a\",4)\n",
    "b = z3.BitVec(\"b\", 4)\n",
    "c = z3.BitVec(\"c\", 4)\n",
    "\n",
    "s = z3.Solver()\n",
    "s.add(a==15)\n",
    "s.add(b==5)\n",
    "s.add(a/b==c)\n",
    "print(s.check())\n",
    "print(s.model())"
   ]
  },
